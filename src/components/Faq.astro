---
import type { Faq } from "../layouts/Layout.astro";

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;
---

{/* Mirrors the FAQPage schema emitted by the layout — same questions, one source. */}
<h2>Common questions</h2>
{
  faqs.map((faq) => (
    <details class="faq">
      <summary>{faq.q}</summary>
      <p>{faq.a}</p>
    </details>
  ))
}
