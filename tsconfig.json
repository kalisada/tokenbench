{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": [
      "vitest/globals",
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@lib/*": [
        "./src/lib/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "functions/**/*",
    "*.config.ts",
    "*.config.mjs"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
